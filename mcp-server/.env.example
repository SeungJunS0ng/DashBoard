DASHBOARD_API_BASE_URL=https://api.43.201.141.9.nip.io

# MVP에서는 사용자가 login tool로 토큰을 발급받는 흐름을 기본으로 둡니다.
# 자동 테스트용 고정 토큰이 필요할 때만 설정하세요.
DASHBOARD_API_TOKEN=

# 자체 서명/개발 인증서를 쓰는 환경에서만 false로 둡니다.
DASHBOARD_TLS_REJECT_UNAUTHORIZED=false

# Local LLM runtime for natural-language orchestration.
# Ollama default server URL is http://localhost:11434.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
